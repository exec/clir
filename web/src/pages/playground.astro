---
import Layout from "../components/Layout.astro";
import Playground from "../components/Playground.tsx";
import { loadAllExamples } from "../lib/examples";
import "../styles/global.css";

// Pass all (slug, code) pairs to the client component so it can resolve
// ?example=<slug> at runtime. The Astro page is rendered statically; the
// query string is only known in the browser, not at build time.
const examples = loadAllExamples().map((e) => ({ slug: e.slug, code: e.code }));
---

<Layout title="clir playground">
  <section class="max-w-7xl mx-auto px-6 py-6">
    <h1 class="text-2xl font-semibold mb-2">Playground</h1>
    <p class="opacity-70 mb-6 text-sm">
      Real Python in your browser. First run boots Pyodide and installs the clir wheel — takes a few seconds.
    </p>
    <Playground client:load examples={examples} />
  </section>
</Layout>
